STORE_CORS=http://localhost:8000,https://docs.medusajs.com

# Comma-separated allowed *origins* (scheme + host + port, no path). Browsers send an exact Origin header;
# if it is missing here, login and admin API calls fail with CORS on /auth/* and /admin/*.
# Local dev examples:
ADMIN_CORS=http://localhost:5173,http://localhost:9000,https://localhost,https://docs.medusajs.com
AUTH_CORS=http://localhost:5173,http://localhost:9000,https://localhost,https://docs.medusajs.com
# Production (Azure): include your storefront, deployed admin origin if any, and every host where you open Admin:
# ADMIN_CORS=https://your-store.azurewebsites.net,https://your-backend.azurewebsites.net,https://localhost
# AUTH_CORS=https://your-store.azurewebsites.net,https://your-backend.azurewebsites.net,https://localhost

# Public origin of the Medusa API (no trailing slash). Used by admin extensions and file URLs for the local file provider (…/static/...).
MEDUSA_BACKEND_URL=http://localhost:9000
# Optional: override only for uploaded file public URLs (defaults to MEDUSA_BACKEND_URL + /static)
# MEDUSA_FILE_BACKEND_URL=https://your-cdn.example.com

REDIS_URL=redis://localhost:6379
JWT_SECRET=supersecret
COOKIE_SECRET=supersecret
DATABASE_URL=
DB_NAME=medusa-v2
